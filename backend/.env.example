# ─────────────────────────────────────────────────────────────
# .env.example file — configuration for the PSX Portfolio Tracker
# ─────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-long-random-string

# ── Supabase / PostgreSQL Connection ─────────────────────────
# Direct connection URI (recommended for migrations & long-lived processes):
# Format: postgresql://<username>:<password>@<host>:<port>/<dbname>
DATABASE_URL=your-supabase-postgresql-connection-string

# ── Price Ingestion Settings ──────────────────────────────────
# Default number of days to look back when running ingestion
INGESTION_LOOKBACK_DAYS=30

# Comma-separated list of default tickers to ingest
DEFAULT_TICKERS=ENGRO,HUBC,LUCK,MCB,OGDC,PPL,PSO,HBL,UBL,EFERT

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Your Supabase project URL (format: https://<project-ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# JWT Secret for verifying Supabase-issued JWTs on the Flask backend.
# Find this in: Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase Anon Key — used by the React frontend (copy to frontend/.env too)
# Find this in: Supabase Dashboard > Settings > API > Project API Keys
SUPABASE_ANON_KEY=your-supabase-anon-key
