# ─────────────────────────────────────────────────────────────
# .env file — configuration for the PSX Portfolio Tracker
# ─────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-long-random-string

# ── Supabase / PostgreSQL Connection ─────────────────────────
# Direct connection (recommended for migrations & long-lived processes):
DATABASE_URL=postgresql://postgres.uzttxleyfdyakyoxxvca:Chalhatnikal.1@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# ── Price Ingestion Settings ──────────────────────────────────
# Default number of days to look back when running ingestion
INGESTION_LOOKBACK_DAYS=30

# Comma-separated list of default tickers to ingest
DEFAULT_TICKERS=ENGRO,HUBC,LUCK,MCB,OGDC,PPL,PSO,HBL,UBL,EFERT

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Your Supabase project URL (format: https://<project-ref>.supabase.co)
SUPABASE_URL=https://uzttxleyfdyakyoxxvca.supabase.co

# JWT Secret for verifying Supabase-issued JWTs on the Flask backend.
# Find this in: Supabase Dashboard > Settings > API > JWT Secret
# This is NOT the anon key or service_role key.
SUPABASE_JWT_SECRET=rHYCbdvpJDStv7jcX0B6ee8ULRgcKzo59dJ/7wLSNWkANnvDyHzyiRqNGhWGbe9Br/mjU0ffwruY3qxBtmq9WA==

# Supabase Anon Key — used by the React frontend (copy to frontend/.env too)
# Find this in: Supabase Dashboard > Settings > API > Project API Keys
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV6dHR4bGV5ZmR5YWt5b3h4dmNhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMxNDgzNjYsImV4cCI6MjA5ODcyNDM2Nn0.9N8D1kVLgBkTTQRcVIeaTct7ZLZXVb6KO-qmFJP5sqQ
